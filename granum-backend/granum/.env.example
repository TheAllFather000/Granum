# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3000

# ── Database ─────────────────────────────────────────────────────
DB_HOST=localhost        # use 'db' when running inside Docker
DB_PORT=5432
DB_NAME=linkhive
DB_USER=linkhive
DB_PASSWORD=linkhive_secret

# ── Redis ─────────────────────────────────────────────────────────
REDIS_HOST=localhost     # use 'redis' when running inside Docker
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=replace_me_with_a_long_random_string_minimum_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Email (nodemailer) ────────────────────────────────────────────
# For Gmail: use an App Password (not your real password)
# https://support.google.com/accounts/answer/185833
# For other providers (SendGrid, Mailgun etc.) swap host/port accordingly
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=Linkhive <noreply@linkhive.co.za>

# ── Twilio SMS ────────────────────────────────────────────────────
# Sign up at twilio.com — free trial gives you ~R300 credit
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890   # your Twilio number

# ── OTP ──────────────────────────────────────────────────────────
OTP_TTL_SECONDS=300        # OTP expires after 5 minutes
OTP_LENGTH=6

# ── Frontend origin (CORS) ─────────────────────────────────────
CORS_ORIGIN=http://localhost:5500   # Live Server default port
